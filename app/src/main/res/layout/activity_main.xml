<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvInput"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:padding="16dp"
        android:text=""
        android:textColor="#212121"
        android:textSize="48sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

        <Button style="@style/CalcButton" android:text="C" android:id="@+id/btnClear" android:textColor="#FF5722"/>
        <Button style="@style/CalcButton" android:text="(" android:id="@+id/btnBracketOpen"/>
        <Button style="@style/CalcButton" android:text=")" android:id="@+id/btnBracketClose"/>
        <Button style="@style/CalcButton" android:text="/" android:id="@+id/btnDivide" android:textColor="#2196F3"/>

        <Button style="@style/CalcButton" android:text="7" android:id="@+id/btn7"/>
        <Button style="@style/CalcButton" android:text="8" android:id="@+id/btn8"/>
        <Button style="@style/CalcButton" android:text="9" android:id="@+id/btn9"/>
        <Button style="@style/CalcButton" android:text="*" android:id="@+id/btnMultiply" android:textColor="#2196F3"/>

        <Button style="@style/CalcButton" android:text="4" android:id="@+id/btn4"/>
        <Button style="@style/CalcButton" android:text="5" android:id="@+id/btn5"/>
        <Button style="@style/CalcButton" android:text="6" android:id="@+id/btn6"/>
        <Button style="@style/CalcButton" android:text="-" android:id="@+id/btnMinus" android:textColor="#2196F3"/>

        <Button style="@style/CalcButton" android:text="1" android:id="@+id/btn1"/>
        <Button style="@style/CalcButton" android:text="2" android:id="@+id/btn2"/>
        <Button style="@style/CalcButton" android:text="3" android:id="@+id/btn3"/>
        <Button style="@style/CalcButton" android:text="+" android:id="@+id/btnPlus" android:textColor="#2196F3"/>

        <Button style="@style/CalcButton" android:text="0" android:id="@+id/btn0" android:layout_columnSpan="2" android:layout_gravity="fill_horizontal"/>
        <Button style="@style/CalcButton" android:text="." android:id="@+id/btnDot"/>
        <Button style="@style/CalcButton" android:text="=" android:id="@+id/btnEqual" android:backgroundTint="#2196F3" android:textColor="#FFFFFF"/>

    </GridLayout>
</LinearLayout>